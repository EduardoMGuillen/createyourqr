DATABASE_URL="postgresql://username:password@ep-your-neon-host.neon.tech/dbname?sslmode=require"
# Production: must match the exact public URL of the site (https, no trailing slash).
# Google OAuth redirect_uri is derived from this — if it mismatches your real domain you get Error 400: redirect_uri_mismatch.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Cloud Console → Credentials → OAuth Web client → Authorized redirect URIs (add every URL you use):
#   http://localhost:3000/api/auth/callback/google
#   https://TU-DOMINIO.com/api/auth/callback/google
#   https://TU-PROYECTO.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# PayPal — minimal set (matches a common Vercel / other-project layout):
#   PAYPAL_API_BASE + PAYPAL_CLIENT_SECRET + NEXT_PUBLIC_PAYPAL_CLIENT_ID
# Production API: https://api-m.paypal.com  |  Sandbox: https://api-m.sandbox.paypal.com
PAYPAL_API_BASE="https://api-m.sandbox.paypal.com"
PAYPAL_CLIENT_SECRET=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
# Subscriptions (Smart Buttons + server): billing plan id (P-...). Can also use NEXT_PUBLIC_PAYPAL_PLAN_ID.
PAYPAL_PLAN_ID=""
NEXT_PUBLIC_PAYPAL_PLAN_ID=""
# Webhook signature verification (optional in dev).
PAYPAL_WEBHOOK_ID=""
# If PAYPAL_API_BASE is not set, sandbox vs live is chosen from:
PAYPAL_ENVIRONMENT="sandbox"
# Optional duplicate of NEXT_PUBLIC_PAYPAL_CLIENT_ID for server-only Basic auth in some setups.
PAYPAL_CLIENT_ID=""

IP_HASH_SALT="replace-with-random-salt"

# Resend (welcome email after sign-up). Get API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Optional. Default: CreateYourQR <onboarding@resend.dev> (ok for testing). Use your verified domain in production, e.g. CreateYourQR <hello@yourdomain.com>
RESEND_FROM=""
